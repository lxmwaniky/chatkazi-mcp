{
  "name": "@lxmwaniky/chatkazi-mcp",
  "version": "1.0.3",
  "description": "An implementation of the Model Context Protocol (MCP) designed to act as a bridge between an MCP-compliant client and the ChatKazi WhatsApp API gateway.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lxmwaniky/chatkazi-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/lxmwaniky/chatkazi-mcp/issues"
  },
  "homepage": "https://github.com/lxmwaniky/chatkazi-mcp#readme",
  "main": "build/index.js",
  "bin": {
    "chatkazi-mcp": "./build/index.js"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "postbuild": "chmod +x build/index.js",
    "watch": "tsc -w",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "build"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "chatkazi",
    "whatsapp",
    "whatsapp-api",
    "mcp-server"
  ],
  "author": "Alex Nyambura",
  "license": "ISC",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25.9.1",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3"
  }
}
